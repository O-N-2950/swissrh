# SWISSRH — Variables d'environnement
# Copier en .env et remplir les valeurs

# PostgreSQL (Railway)
DATABASE_URL=postgresql://user:password@host:5432/swissrh

# JWT — générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez-moi-en-production

# Environnement
NODE_ENV=development
PORT=5000

# Email (Resend — optionnel pour alertes crash monitor)
# RESEND_API_KEY=re_xxxx
# ADMIN_EMAIL=admin@swissrh.ch
