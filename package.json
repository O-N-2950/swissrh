  "description": "SWISSRH \u2014 Swiss HR & Payroll SaaS for SMEs. Swiss HR & Payroll \u2014 taux 2025 officiels.",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/index.ts",
    "build": "cd client && npm ci && npx vite build && cd .. && npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
