    "react-dom": "^19.1.1",
    "recharts": "^2.15.3",
    "wouter": "^3.7.1",
    "zod": "^3.24.4",
    "pdfkit": "^0.15.0",
    "@types/pdfkit": "^0.13.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
